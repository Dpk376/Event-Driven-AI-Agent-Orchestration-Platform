# ---------------------------------------------------------------------------
# Event-Driven AI Agent Orchestration Platform - Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=eventagent
POSTGRES_PASSWORD=eventagent_dev
POSTGRES_DB=eventagent

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# Supported providers: openai, fake
LLM_API_KEY=your-api-key-here
LLM_PROVIDER=fake
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# API Security
# ---------------------------------------------------------------------------
API_KEY=dev-api-key-12345

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---------------------------------------------------------------------------
# Token Budget (Rate Limiting)
# ---------------------------------------------------------------------------
TOKEN_BUDGET_PER_MINUTE=100000
TOKEN_BUDGET_PER_HOUR=1000000
